# ============================================================
# CONDISABOR — Backend API
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env real a un repositorio.
#
# En Render se configuran en: Dashboard → tu servicio → Environment
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production          # development | production

# ── Supabase ─────────────────────────────────────────────────
# Obtenlos en: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── CORS ─────────────────────────────────────────────────────
# Dominio(s) del frontend. Separar multiples con coma.
# En DESARROLLO: http://localhost:5173
# En PRODUCCION (Vercel): https://condisabor.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ── Seguridad HTTPS ──────────────────────────────────────────
# true en produccion (Koyeb provee HTTPS automaticamente).
# false solo en desarrollo local.
FORCE_HTTPS=false

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos en ms
RATE_LIMIT_MAX=100           # Maximo de requests por ventana

# ── Cron jobs ────────────────────────────────────────────────
# Ejecutar el job de facturas vencidas al arrancar (util para pruebas)
RUN_CRON_ON_START=false

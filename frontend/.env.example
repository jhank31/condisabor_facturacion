# ============================================================
# CONDISABOR — Frontend
# Copia este archivo como .env y completa los valores reales.
#
# IMPORTANTE: Vite embebe estas variables en el bundle JS
# en tiempo de BUILD, no en tiempo de ejecución.
# En Vercel se configuran en el dashboard (Settings → Environment Variables).
# ============================================================

# ── Supabase (requeridas en build time) ──────────────────────
# Obtenlas en: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ── API URL ──────────────────────────────────────────────────
# En DESARROLLO: dejar vacío o no definir. El proxy de Vite
# (vite.config.js) redirige /api → localhost:3000 automáticamente.
#
# En PRODUCCIÓN (Vercel + Render): poner la URL del backend en Render.
# Ejemplo: https://condisabor-backend.onrender.com
VITE_API_URL=

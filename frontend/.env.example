# ============================================================
# CONDISABOR — Frontend
# Copia este archivo como .env y completa los valores reales.
#
# IMPORTANTE: Vite embebe estas variables en el bundle JS
# en tiempo de BUILD, no en tiempo de ejecución.
# Deben pasarse como --build-arg en Docker.
# ============================================================

# ── Supabase (requeridas en build time) ──────────────────────
# Obtenlas en: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ── API URL ──────────────────────────────────────────────────
# En DESARROLLO: dejar vacío. El proxy de Vite (vite.config.js)
# redirige /api → localhost:3000 automáticamente.
#
# En PRODUCCIÓN con Docker: NO es necesario. Nginx se encarga
# de hacer el proxy /api → backend:3000.
#
# Solo definir si el backend está en un host externo diferente:
# VITE_API_URL=https://api.midominio.com

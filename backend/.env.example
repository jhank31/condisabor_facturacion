# ============================================================
# CONDISABOR — Backend API
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env real a un repositorio.
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production          # development | production

# ── Supabase ─────────────────────────────────────────────────
# Obtenlos en: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── CORS ─────────────────────────────────────────────────────
# IP o dominio del frontend. Separar múltiples con coma.
# En VPN interna usar la IP privada, ej: http://192.168.1.50:5173
# En producción con nginx: http://192.168.1.50 (sin puerto)
ALLOWED_ORIGINS=http://localhost:5173

# ── Seguridad HTTPS ──────────────────────────────────────────
# Activar HSTS solo si el servidor tiene certificado SSL válido.
# En red privada (VPN) sin certificados, dejar en false.
FORCE_HTTPS=false

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos en ms
RATE_LIMIT_MAX=100           # Máximo de requests por ventana

# ── Cron jobs ────────────────────────────────────────────────
# Ejecutar el job de facturas vencidas al arrancar (útil para pruebas)
RUN_CRON_ON_START=false

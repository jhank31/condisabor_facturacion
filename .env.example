# ============================================================================
# CONDISABOR — Variables de Entorno para Supabase Self-Hosted
# ============================================================================
# Copiar este archivo a .env y configurar los valores antes de ejecutar
# docker compose up -d
# ============================================================================

# ============================================================================
# PostgreSQL
# ============================================================================
POSTGRES_PASSWORD=tu-contraseña-segura-aqui-minimo-32-chars
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ============================================================================
# JWT — Secreto compartido para firmar tokens
# Genera uno con: openssl rand -base64 64 | tr -d '\n'
# DEBE tener al menos 32 caracteres
# ============================================================================
JWT_SECRET=tu-jwt-secret-super-seguro-de-al-menos-32-caracteres
JWT_EXP=3600

# ============================================================================
# API Keys — Generadas a partir del JWT_SECRET
# Usa https://supabase.com/docs/guides/self-hosting#api-keys para generarlas
# o usa el script: npx supabase-keys generate --jwt-secret="TU_JWT_SECRET"
# ============================================================================
# ANON_KEY: clave pública para operaciones anónimas (RLS se aplica)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CAMBIAR_ESTO

# SERVICE_ROLE_KEY: clave privada que bypasea RLS (NUNCA exponer al frontend)
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CAMBIAR_ESTO

# ============================================================================
# URLs
# ============================================================================
# URL externa de la API (cómo el frontend accede a Supabase)
API_EXTERNAL_URL=http://localhost:8001

# URL del sitio frontend (para redirecciones de auth)
SITE_URL=http://localhost:3000

# URLs adicionales permitidas para redirección (separadas por coma)
ADDITIONAL_REDIRECT_URLS=

# ============================================================================
# Puertos de servicios
# ============================================================================
STUDIO_PORT=8000
API_PORT=8001
API_EXTERNAL_PORT=8443

# ============================================================================
# Auth (GoTrue)
# ============================================================================
# true = solo admins pueden crear usuarios (recomendado para sistema interno)
DISABLE_SIGNUP=true

# ============================================================================
# Seguridad adicional
# ============================================================================
# Clave base para Realtime (genera con: openssl rand -base64 48)
SECRET_KEY_BASE=tu-secret-key-base-de-al-menos-64-caracteres-generada-con-openssl
